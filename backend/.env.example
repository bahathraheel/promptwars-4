# StadiumPulse AI – Environment Variables
# Copy to .env and fill in real values. NEVER commit .env to version control.

# Anthropic API Key (required)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Server config
PORT=3001
NODE_ENV=development

# CORS origin for frontend
CORS_ORIGIN=http://localhost:5173

# Rate limiting (requests per window)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=60

# Knowledge base path (relative to backend root)
KNOWLEDGE_BASE_PATH=../knowledge-base

# Retrieval confidence threshold (0–1). Below this, assistant refuses and redirects.
RETRIEVAL_CONFIDENCE_THRESHOLD=0.25

# Gemini API Key (optional — if set, default to Gemini model)
GEMINI_API_KEY=your_gemini_key_here


{
  "preset": "ts-jest",
  "testEnvironment": "node",
  "roots": ["<rootDir>/src"],
  "testMatch": ["**/__tests__/**/*.test.ts", "**/*.test.ts"],
  "collectCoverageFrom": ["src/**/*.ts", "!src/server.ts"],
  "coverageThreshold": {
    "global": { "branches": 60, "functions": 70, "lines": 70, "statements": 70 }
  },
  "moduleNameMapper": {
    "^(\\.\\.?/.*)\\.js$": "$1"
  },
  "transform": {
    "^.+\\.ts$": ["ts-jest", {
      "tsconfig": "tsconfig.json",
      "diagnostics": {
        "ignoreDiagnostics": [6133]
      }
    }]
  }
}
